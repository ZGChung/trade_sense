# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Free Gemini (optional but recommended)
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# MiniMax fallback (optional, only used when Gemini hits 429 rate limit)
VITE_MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY
VITE_MINIMAX_MODEL=MiniMax-M2.5
VITE_MINIMAX_BASE_URL=https://api.minimax.io/v1

# Legacy DeepSeek key (optional, only when user chooses DeepSeek in AI settings)
VITE_DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
